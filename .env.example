ENVIRONMENT=local
TOKENIZERS_PARALLELISM=false
CHROMA_DIR=chroma_db
STORAGE_DIR=storage
ANONYMIZED_TELEMETRY=false

GOOGLE_API_KEY=your-google-api-key-here

CORS_ORIGINS=http://localhost:3000

# Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Prepend a one-sentence context to each chunk before embedding (improves recall)
CONTEXTUAL_RETRIEVAL=true

# Semantic cache — requires Redis Stack (included in docker-compose)
REDIS_URL=redis://localhost:6379
SEMANTIC_CACHE_THRESHOLD=0.97
CACHE_TTL_SECONDS=86400

# HyDE fires a hypothetical-passage retrieval when reranker confidence is low
HYDE_THRESHOLD=0.3

# Set to true to extract and caption figures from PDFs using Gemini Vision (capped at 30/doc)
EXTRACT_FIGURES=true

# Full path to the tesseract binary — set this if tesseract is not on PATH or the wrong version is picked up
# macOS Homebrew: /opt/homebrew/bin/tesseract   conda: /opt/anaconda3/bin/tesseract
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
