ENVIRONMENT=local
CHROMA_DIR=chroma_db
STORAGE_DIR=storage
ANONYMIZED_TELEMETRY=false

# Google Gemini API key — required for LLM-powered answer generation
GOOGLE_API_KEY=your-google-api-key-here

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:8501

# Contextual Retrieval (Anthropic technique): prepends a one-sentence context to each
# chunk before embedding to improve retrieval recall. Requires GOOGLE_API_KEY.
# Results are cached in ~/.documind/context_cache.db so re-ingestion is free.
CONTEXTUAL_RETRIEVAL=true
